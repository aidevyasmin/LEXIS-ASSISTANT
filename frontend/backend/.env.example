# Nisar Hussain Virtual Law Chamber - Backend Environment Template

# Server Configuration
PORT=5000
NODE_ENV=development

# Security (AES-256)
ENCRYPTION_KEY=your_32_character_encryption_key_here

# AI Configuration (Server-Side Only)
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration (PostgreSQL with SSL for production)
DATABASE_URL=postgresql://user:password@localhost:5432/lexis_db

# Calendar Integration
GOOGLE_CALENDAR_ID=your_calendar_id_here
GOOGLE_SERVICE_ACCOUNT_KEY=your_service_account_json_base64_here

# Payments (EasyPaisa/JazzCash Manual Verification or API)
PAYMENT_SECRET=your_payment_webhook_secret_here

# JWT Security
JWT_SECRET=your_super_secret_jwt_string_here
