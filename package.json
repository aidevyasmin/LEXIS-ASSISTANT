{
  "name": "lexis-assistant-root",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "frontend/backend"
  ],
  "scripts": {
    "dev": "npm run dev -w lexis-assistant",
    "build": "npm run build-backend && npm run build-frontend",
    "build-frontend": "npm run build -w lexis-assistant",
    "build-backend": "npm run build -w backend",
    "install-all": "npm install"
  }
}
