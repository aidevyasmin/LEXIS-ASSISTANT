{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/auth/(.*)", "destination": "/api/index.js" },
    { "source": "/uploads/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api|auth|uploads).*)", "destination": "/frontend/dist/$1" },
    { "source": "/", "destination": "/frontend/dist/index.html" }
  ]
}
