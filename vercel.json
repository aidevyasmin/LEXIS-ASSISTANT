{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    },
    {
      "src": "frontend/api/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "frontend/api/index.js" },
    { "source": "/auth/(.*)", "destination": "frontend/api/index.js" },
    { "source": "/uploads/(.*)", "destination": "frontend/api/index.js" },
    { "source": "/((?!api|auth|uploads).*)", "destination": "/frontend/dist/$1" },
    { "source": "/", "destination": "/frontend/dist/index.html" }
  ]
}
